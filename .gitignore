# OS / editor cruft
.DS_Store

# Python
__pycache__/
*.py[cod]

# Generated engagement working output (disposable renders — re-created per run).
# The kit itself is tracked; an engagement's files are not.
.keel/
deliverables/
discovery/
sample-inputs/

# …except the maintained regression fixtures under examples/, whose engagement
# state IS the test (checks/test_examples.sh reconciles the gates against it).
!examples/**/.keel/
!examples/**/.keel/**
!examples/**/deliverables/
!examples/**/deliverables/**
!examples/**/discovery/
!examples/**/discovery/**
