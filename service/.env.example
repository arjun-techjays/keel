# Supabase project — from Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-only; bypasses RLS. Never ship to the client.
SUPABASE_JWT_SECRET=your-jwt-secret          # Project Settings → API → JWT Secret (HS256)

# Pinned standard + gate engine (paths inside the container; see Dockerfile)
CHECKS_DIR=/app/checks
CONSTITUTION_PATH=/app/constitution.md

# Lease length for the whole-project checkout lock
LEASE_TTL_MINUTES=15
